# Optional: public site URL for absolute links (used in sitemap, OG, etc.)
# NEXT_PUBLIC_SITE_URL=https://welcomecardecor.com

# Optional: contact email (default: contact@welcomecardecor.com)
# NEXT_PUBLIC_CONTACT_EMAIL=your@email.com

# Optional: Instagram URL (default from site.json)
# NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/yourhandle

# Optional: Formspree form ID for contact form (get from formspree.io). If not set, shows mailto fallback.
# NEXT_PUBLIC_FORMSPREE_ID=xxxxxxxx

# Optional: Add whatsapp and phone to src/data/site.json contact section for product page CTAs.
# whatsapp: "919876543210" (country code + number, no +)
# phone: "+919876543210" or "9876543210"

# Optional: Google Analytics ID (e.g. G-XXXXXXXXXX)
# NEXT_PUBLIC_GA_ID=
